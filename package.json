{
  "name": "project-meridian",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsx watch server/index.ts\"",
    "build": "tsc -b && vite build && tsc -p tsconfig.server.json",
    "deploy:gcp": "bash scripts/deploy-cloud-run.sh",
    "gcp-build": "npm run build",
    "start": "node dist-server/index.js",
    "typecheck": "tsc -b --pretty false",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@google-cloud/firestore": "^8.6.0",
    "@google/genai": "^1.27.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "firebase": "^12.15.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.468.0",
    "motion": "^12.23.24",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "vite": "^7.2.2"
  }
}
