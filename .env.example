GEMINI_API_KEY=replace_with_your_google_ai_studio_key
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_GUIDE_MODEL=gemini-3.1-flash-lite
# Optional: set only if AI Studio "Get code" confirms the exact Gemma model id for your key.
GEMMA_MODEL=
PORT=8080
ENABLE_FIRESTORE=false
FIRESTORE_DATABASE=(default)
FIREBASE_WEB_API_KEY=replace_with_restricted_identity_platform_browser_key
FIREBASE_PROJECT_ID=meridian-vibe2ship
FIREBASE_AUTH_DOMAIN=meridian-vibe2ship.firebaseapp.com
